{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "target": "ES6",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "**/*.js",
    "**/*.jsx",
    "app/api/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".claude"
  ]
}
